{
  "functions": {
    "source": "functions"
  },
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/createUpiSubscriptionOrder",
        "function": {
          "functionId": "createUpiSubscriptionOrder",
          "region": "asia-south1"
        }
      },
      {
        "source": "/verifyUpiSubscriptionPayment",
        "function": {
          "functionId": "verifyUpiSubscriptionPayment",
          "region": "asia-south1"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
