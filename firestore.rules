rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == "W7dU0vbtEtPG5rn7CXoxLsbcs483" ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
        )
      );
    }

    function isTrialActivationForSelf(userId) {
      return isOwner(userId) &&
        resource.data.role == request.resource.data.role &&
        resource.data.blocked == request.resource.data.blocked &&
        resource.data.sharedLedgerId == request.resource.data.sharedLedgerId &&
        resource.data.sharedLedgerRole == request.resource.data.sharedLedgerRole &&
        resource.data.plan == "free" &&
        resource.data.subscriptionStatus == "active" &&
        resource.data.subscriptionEndsAt == "" &&
        resource.data.trialEligible == true &&
        resource.data.trialStartedAt == "" &&
        request.resource.data.plan == "pro" &&
        request.resource.data.subscriptionStatus == "trial" &&
        request.resource.data.trialEligible == false;
    }

    function isTrialExpiryDowngradeForSelf(userId) {
      return isOwner(userId) &&
        resource.data.role == request.resource.data.role &&
        resource.data.blocked == request.resource.data.blocked &&
        resource.data.sharedLedgerId == request.resource.data.sharedLedgerId &&
        resource.data.sharedLedgerRole == request.resource.data.sharedLedgerRole &&
        resource.data.email == request.resource.data.email &&
        resource.data.plan == "pro" &&
        resource.data.subscriptionStatus == "trial" &&
        resource.data.trialEligible == false &&
        request.resource.data.plan == "free" &&
        request.resource.data.subscriptionStatus == "active" &&
        request.resource.data.subscriptionEndsAt == "" &&
        request.resource.data.trialEligible == false;
    }

    function isSafeSocietyPortalJoin(userId) {
      return isOwner(userId) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "societyPortalId",
          "societyPortalRole",
          "societyFlatNumber",
          "societyInviteCode",
          "apartmentPortalRoles",
          "updatedAt",
          "lastActivityAt"
        ]) &&
        request.resource.data.societyPortalRole == "member" &&
        request.resource.data.societyPortalId is string &&
        request.resource.data.societyPortalId != "" &&
        request.resource.data.societyInviteCode is string &&
        request.resource.data.societyInviteCode != "" &&
        exists(/databases/$(database)/documents/society_invites/$(request.resource.data.societyInviteCode)) &&
        get(/databases/$(database)/documents/society_invites/$(request.resource.data.societyInviteCode)).data.isActive == true &&
        get(/databases/$(database)/documents/society_invites/$(request.resource.data.societyInviteCode)).data.portalId == request.resource.data.societyPortalId &&
        get(/databases/$(database)/documents/society_invites/$(request.resource.data.societyInviteCode)).data.flatNumber == request.resource.data.societyFlatNumber &&
        get(/databases/$(database)/documents/society_invites/$(request.resource.data.societyInviteCode)).data.allowedEmail == request.auth.token.email &&
        request.resource.data.apartmentPortalRoles[request.resource.data.societyPortalId] == "resident";
    }

    function isSafeSocietyPortalLeave(userId) {
      return isOwner(userId) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "societyPortalId",
          "societyPortalRole",
          "societyFlatNumber",
          "societyInviteCode",
          "apartmentPortalRoles",
          "updatedAt",
          "lastActivityAt"
        ]) &&
        request.resource.data.societyPortalId == "" &&
        request.resource.data.societyPortalRole == "" &&
        request.resource.data.societyFlatNumber == "" &&
        request.resource.data.societyInviteCode == "";
    }

    function isSafeOwnerUserUpdate(userId) {
      return isOwner(userId) && (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "name",
          "email",
          "phone",
          "phoneCountryCode",
          "gender",
          "dateOfBirth",
          "ageGroup",
          "addressLine",
          "city",
          "state",
          "country",
          "location",
          "address",
          "organizationType",
          "activeOrgId",
          "orgs",
          "onboardingSeenAt",
          "role",
          "plan",
          "subscriptionStatus",
          "subscriptionEndsAt",
          "trialEligible",
          "trialStartedAt",
          "blocked",
          "sharedLedgerId",
          "sharedLedgerRole",
          "societyPortalId",
          "societyPortalRole",
          "societyFlatNumber",
          "societyInviteCode",
          "apartmentPortalRoles",
          "legalAccepted",
          "termsVersion",
          "termsAcceptedAt",
          "privacyAcceptedAt",
          "refundsPolicyAcceptedAt",
          "updatedAt",
          "lastActivityAt",
          "analytics"
        ]) &&
        (
          resource.data.role == request.resource.data.role &&
          resource.data.plan == request.resource.data.plan &&
          resource.data.subscriptionStatus == request.resource.data.subscriptionStatus &&
          resource.data.subscriptionEndsAt == request.resource.data.subscriptionEndsAt &&
          resource.data.trialEligible == request.resource.data.trialEligible &&
          resource.data.trialStartedAt == request.resource.data.trialStartedAt &&
          resource.data.blocked == request.resource.data.blocked &&
          resource.data.sharedLedgerId == request.resource.data.sharedLedgerId &&
          resource.data.sharedLedgerRole == request.resource.data.sharedLedgerRole &&
          (("societyPortalId" in resource.data) ? resource.data.societyPortalId : "") == (("societyPortalId" in request.resource.data) ? request.resource.data.societyPortalId : "") &&
          (("societyPortalRole" in resource.data) ? resource.data.societyPortalRole : "") == (("societyPortalRole" in request.resource.data) ? request.resource.data.societyPortalRole : "") &&
          (("societyFlatNumber" in resource.data) ? resource.data.societyFlatNumber : "") == (("societyFlatNumber" in request.resource.data) ? request.resource.data.societyFlatNumber : "") &&
          (("societyInviteCode" in resource.data) ? resource.data.societyInviteCode : "") == (("societyInviteCode" in request.resource.data) ? request.resource.data.societyInviteCode : "") &&
          resource.data.apartmentPortalRoles == request.resource.data.apartmentPortalRoles &&
          resource.data.email == request.resource.data.email
        ) ||
        isSafeSocietyPortalJoin(userId) ||
        isSafeSocietyPortalLeave(userId) ||
        isTrialActivationForSelf(userId) ||
        isTrialExpiryDowngradeForSelf(userId)
      );
    }

    function isValidOwnerUserCreate(userId) {
      return isOwner(userId) &&
        request.resource.data.role == "user" &&
        request.resource.data.plan == "free" &&
        request.resource.data.subscriptionStatus == "active" &&
        request.resource.data.subscriptionEndsAt == "" &&
        request.resource.data.trialEligible == true &&
        request.resource.data.trialStartedAt == "" &&
        request.resource.data.blocked == false &&
        request.resource.data.sharedLedgerId == "" &&
        request.resource.data.sharedLedgerRole == "" &&
        request.resource.data.societyPortalId == "" &&
        request.resource.data.societyPortalRole == "" &&
        request.resource.data.societyFlatNumber == "" &&
        request.resource.data.societyInviteCode == "" &&
        request.resource.data.apartmentPortalRoles == {} &&
        request.resource.data.legalAccepted == true &&
        request.resource.data.termsVersion is string && request.resource.data.termsVersion != "" &&
        request.resource.data.termsAcceptedAt is string && request.resource.data.termsAcceptedAt != "" &&
        request.resource.data.privacyAcceptedAt is string && request.resource.data.privacyAcceptedAt != "" &&
        request.resource.data.refundsPolicyAcceptedAt is string && request.resource.data.refundsPolicyAcceptedAt != "" &&
        request.resource.data.email == request.auth.token.email;
    }

    function isSharedLedgerOwnerByDoc() {
      return isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    function isSharedLedgerMetadataUnchanged() {
      return resource.data.ownerId == request.resource.data.ownerId &&
        resource.data.inviteCode == request.resource.data.inviteCode &&
        resource.data.members == request.resource.data.members &&
        resource.data.name == request.resource.data.name;
    }

    function isSafeSupportTicketUserUpdate() {
      return isSignedIn() &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "messages",
          "status",
          "updatedAt",
          "lastUserReplyAt"
        ]) &&
        request.resource.data.userId == resource.data.userId &&
        request.resource.data.subject == resource.data.subject &&
        request.resource.data.message == resource.data.message &&
        request.resource.data.topic == resource.data.topic &&
        request.resource.data.createdAt == resource.data.createdAt &&
        request.resource.data.status == "open";
    }

    function isPortalMember(portalId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.apartmentPortalRoles[portalId] == "resident";
    }

    function isPortalOwner(portalId) {
      return isSignedIn() &&
        (
          (
            exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.apartmentPortalRoles[portalId] == "admin"
          ) ||
          (
            exists(/databases/$(database)/documents/society_portals/$(portalId)) &&
            get(/databases/$(database)/documents/society_portals/$(portalId)).data.ownerId == request.auth.uid
          )
        );
    }

    function canReadPortal(portalId) {
      return isAdmin() || isPortalOwner(portalId) || isPortalMember(portalId);
    }

    match /users/{userId} {
      allow create: if isAdmin() || isValidOwnerUserCreate(userId);
      allow read: if isOwner(userId) || isAdmin();
      allow update: if isAdmin() || isSafeOwnerUserUpdate(userId);
      allow delete: if isAdmin() && request.auth.uid != userId;

      match /orgs/{orgId}/invoices/{invoiceId} {
        allow create, read, update, delete: if isOwner(userId) || isAdmin();
      }

      match /orgs/{orgId}/income/{incomeId} {
        allow create, read, update, delete: if isOwner(userId) || isAdmin();
      }

      match /orgs/{orgId}/expenses/{expenseId} {
        allow create, read, update, delete: if isOwner(userId) || isAdmin();
      }
    }

    match /shared_ledgers/{ledgerId} {
      allow read, write: if false;
    }

    match /admin_cleanup_queue/{requestId} {
      allow create: if isAdmin();
      allow read, update, delete: if isAdmin();
    }

    match /payment_requests/{requestId} {
      allow create: if isSignedIn() &&
        (
          request.auth.uid == requestId ||
          request.resource.data.userId == request.auth.uid
        ) &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.status == "pending" &&
        request.resource.data.requestedPlan in ["pro", "business"] &&
        request.resource.data.billingCycle in ["monthly", "yearly"] &&
        request.resource.data.amount is number &&
        request.resource.data.amount >= 0;
      allow read: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid || request.auth.uid == requestId);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /support_tickets/{ticketId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update: if isAdmin() || isSafeSupportTicketUserUpdate();
      allow delete: if isAdmin();
    }

    match /admin_metrics/{metricId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    match /society_invites/{inviteCode} {
      allow read: if isSignedIn();
      allow create: if isAdmin() ||
        (isSignedIn() && request.resource.data.ownerId == request.auth.uid);
      allow update, delete: if isAdmin() ||
        (isSignedIn() && resource.data.ownerId == request.auth.uid);
    }

    match /society_portals/{portalId} {
      allow create: if isAdmin() || (isSignedIn() && request.resource.data.ownerId == request.auth.uid);
      allow read: if canReadPortal(portalId);
      allow update, delete: if isAdmin() || isPortalOwner(portalId);

      match /common_records/{periodId} {
        allow read: if canReadPortal(portalId);
        allow create, update, delete: if isAdmin() || isPortalOwner(portalId);
      }

      match /flat_dues/{flatId} {
        allow read: if isAdmin() ||
          isPortalOwner(portalId) ||
          (
            isPortalMember(portalId) &&
            exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
            resource.data.flatNumber ==
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.societyFlatNumber
          );
        allow create, update, delete: if isAdmin() || isPortalOwner(portalId);
      }

      match /members/{memberId} {
        allow read: if isAdmin() || isPortalOwner(portalId) || (isSignedIn() && request.auth.uid == memberId);
        allow create, update: if isAdmin() || isPortalOwner(portalId);
        allow delete: if isAdmin() || isPortalOwner(portalId) || (isSignedIn() && request.auth.uid == memberId);
      }
    }
  }
}