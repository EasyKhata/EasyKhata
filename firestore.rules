rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == "W7dU0vbtEtPG5rn7CXoxLsbcs483" ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
        )
      );
    }

    match /users/{userId} {
      allow create: if isOwner(userId);
      allow read: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin() && request.auth.uid != userId;

      match /orgs/{orgId}/invoices/{invoiceId} {
        allow create, read, update, delete: if isOwner(userId) || isAdmin();
      }

      match /orgs/{orgId}/income/{incomeId} {
        allow create, read, update, delete: if isOwner(userId) || isAdmin();
      }

      match /orgs/{orgId}/expenses/{expenseId} {
        allow create, read, update, delete: if isOwner(userId) || isAdmin();
      }
    }

    match /shared_ledgers/{ledgerId} {
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow read, update: if isAdmin() ||
        (isSignedIn() && (
          resource.data.ownerId == request.auth.uid ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.sharedLedgerId == ledgerId
        ));
      allow delete: if isAdmin();

      match /invoices/{invoiceId} {
        allow create, read, update, delete: if isAdmin() ||
          (isSignedIn() &&
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.sharedLedgerId == ledgerId);
      }

      match /income/{incomeId} {
        allow create, read, update, delete: if isAdmin() ||
          (isSignedIn() &&
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.sharedLedgerId == ledgerId);
      }

      match /expenses/{expenseId} {
        allow create, read, update, delete: if isAdmin() ||
          (isSignedIn() &&
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.sharedLedgerId == ledgerId);
      }
    }

    match /admin_cleanup_queue/{requestId} {
      allow create: if isAdmin();
      allow read, update, delete: if isAdmin();
    }

    match /payment_requests/{requestId} {
      allow create: if isSignedIn() && request.auth.uid == requestId;
      allow read: if isSignedIn() && (request.auth.uid == requestId || isAdmin());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /support_tickets/{ticketId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }
  }
}