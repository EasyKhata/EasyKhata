rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.uid == "W7dU0vbtEtPG5rn7CXoxLsbcs483";
    }

    match /users/{userId} {
      allow create: if isOwner(userId);
      allow read: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin() && request.auth.uid != userId;
    }

    match /payment_requests/{requestId} {
      allow create: if isSignedIn() && request.auth.uid == requestId;
      allow read: if isSignedIn() && (request.auth.uid == requestId || isAdmin());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}